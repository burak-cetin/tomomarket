Options -Indexes
Options +FollowSymLinks
RewriteEngine On

# ── HTTPS yönlendirmesi ───────────────────────────────
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} tomografimarket\.com$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www -> non-www yönlendirmesi ──────────────────────
RewriteCond %{HTTP_HOST} ^www\.tomografimarket\.com$ [NC]
RewriteRule ^ https://tomografimarket.com%{REQUEST_URI} [L,R=301]

# ── Eski .php uzantili URL'leri 301 ile yonlendir ────
# (Google'daki eski linkler icin)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /%1 [R=301,L]

# ── Eski -detay URL'lerini yonlendir ─────────────────
RewriteRule ^urunler/([a-z0-9\-]+)-detay/?$ /urunler/$1 [R=301,L]

# ── Eski -tomografi URL'lerini yonlendir ─────────────
RewriteRule ^markalar/([a-z0-9\-]+)-tomografi/?$ /markalar/$1 [R=301,L]

# ── Korunan dizinler ─────────────────────────────────
RewriteRule ^config/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^includes/ - [F,L]

# ══════════════════════════════════════════════════════
#  TEMİZ URL KURALLARI (uzantisiz)
# ══════════════════════════════════════════════════════

# ── Markalar: /markalar/vatech → markalar/_brand_page.php?brand=vatech
RewriteRule ^markalar/([a-z0-9\-]+)/?$ markalar/_brand_page.php?brand=$1 [L,QSA]

# ── Ürünler: /urunler/hdxwill-dentio → urunler/_product_detail.php?slug=hdxwill-dentio
RewriteRule ^urunler/([a-z0-9\-]+)/?$ urunler/_product_detail.php?slug=$1 [L,QSA]

# ── Blog: /blog/cbct-nedir → blog/_post.php?slug=cbct-nedir
RewriteCond %{REQUEST_URI} !^/blog/index
RewriteRule ^blog/([a-z0-9\-]+)/?$ blog/_post.php?slug=$1 [L,QSA]

# ── Genel: .php uzantisiz erisim ─────────────────────
# /ikinci-el → ikinci-el.php, /blog → blog/index.php, vb.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# ── Sayfalar dizini ──────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/sayfalar/%{REQUEST_URI}.php -f
RewriteRule ^(sayfalar/.+)$ $1.php [L]

# ── Güvenlik başlıkları ───────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Gzip sıkıştırma ───────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Tarayıcı önbelleği ────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/gif "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

<FilesMatch "^(config|install|composer)\.(php|json|lock)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── Hata sayfaları ────────────────────────────────────
ErrorDocument 404 /404.php
ErrorDocument 500 /500.php
